# Environment for the AWS / Node runtime (the default DEPLOY_TARGET), read from
# process.env by the server functions. Vite loads this file into process.env for
# local `pnpm dev`; in production it comes from ECS / Secrets Manager.
#
# For the CLOUDFLARE runtime, secrets live in `.dev.vars` instead (Worker bindings
# are not read from .env) — see .dev.vars.example and docs/deploy-cloudflare.md.

# Postgres connection string.
#   RDS:  postgres://USER:PASS@your-db.rds.amazonaws.com:5432/quorq?sslmode=require
#   Neon: postgres://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/quorq?sslmode=require
DATABASE_URL=
DATABASE_URL_POOLER=

# HS256 JWT signing key for auth sessions. Any long random string; generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Deploy target: unset (or 'aws') → node-postgres/RDS; 'cloudflare' → Neon HTTP
# driver. Normally set by the build scripts (dev:cf / build:cf), not here — only
# override if you want `pnpm dev` to use the Cloudflare driver locally.
# DEPLOY_TARGET=aws

# Show the one-click "Demo accounts" buttons on the login screen. VITE_-prefixed
# so it reaches the client. Only 'true' shows them; unset/'false' hides them.
# Keep this unset (hidden) in production.
VITE_SHOW_DEMO_ACCOUNTS=false
