# These will be automatically created by Neon Launchpad (https://neon.new).
# You will also need to
DATABASE_URL=
DATABASE_URL_POOLER=

# HS256 JWT signing key for auth sessions. Any long random string; generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=

# Show the one-click "Demo accounts" buttons on the login screen. VITE_-prefixed
# so it reaches the client. Only 'true' shows them; unset/'false' hides them.
# Keep this unset (hidden) in production.
VITE_SHOW_DEMO_ACCOUNTS=false
