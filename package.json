{
  "name": "quorq-hr",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:cf": "DEPLOY_TARGET=cloudflare vite dev --port 3000",
